# RailCall key-sweep — copy to `.env.keys` and paste your REAL test keys.
# `.env.keys` is gitignored (it holds live secrets). Leave a line blank or as PASTE_… to skip it.
# Run:  railcall studio   (then)   python3 scripts/sweep_keys.py
#
# Most of these have a free or test tier — get those, not your production keys.

# ── LLMs / AI ──────────────────────────────────────────────
OPENAI_API_KEY=PASTE_OR_LEAVE_BLANK
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=

# ── Code / CI ──────────────────────────────────────────────
GITHUB_TOKEN=                # github.com/settings/tokens (classic PAT, repo scope)
GITLAB_TOKEN=
LINEAR_API_KEY=

# ── Payments (USE TEST MODE) ───────────────────────────────
STRIPE_SECRET_KEY=           # sk_test_… from dashboard.stripe.com (Test mode)
SQUARE_TOKEN=

# ── Comms ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=             # api.slack.com/apps → Bot Token (free workspace)
SENDGRID_API_KEY=            # free tier
TWILIO_SID=                  # trial account
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# ── CRM / Support ──────────────────────────────────────────
HUBSPOT_TOKEN=               # free developer account
SF_INSTANCE_URL=             # Salesforce Developer Edition (free)
ZENDESK_TOKEN=

# ── Data / Docs ────────────────────────────────────────────
DATABASE_URL=                # local Postgres or a free Supabase/Neon connection string
SUPABASE_URL=
AIRTABLE_TOKEN=
NOTION_TOKEN=                # notion.so/my-integrations (free)
SHEET_WEBHOOK_URL=           # the Apps Script web-app URL for signup→sheet

# ── Analytics / Ops ────────────────────────────────────────
POSTHOG_API_KEY=
SENTRY_DSN=
PAGERDUTY_TOKEN=

# ── Aggregators (prove the bridge story) ───────────────────
ZAPIER_HOOK_URL=
MAKE_WEBHOOK_URL=
N8N_WEBHOOK_URL=
PIPEDREAM_WORKFLOW_URL=
